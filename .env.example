# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ─── Data Source ─────────────────────────────────────────────────────────────
# "mock" uses deterministic generated data (no API keys needed)
# "real" uses yfinance + optional paid providers with mock fallback
DATA_SOURCE=mock

# ─── API Keys (optional, for real data mode) ─────────────────────────────────
ALPHA_VANTAGE_KEY=
FINNHUB_KEY=
POLYGON_KEY=

# ─── Redis (leave default for Docker Compose) ────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_TTL_SECONDS=300

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000
